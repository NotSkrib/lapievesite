# Airbnb + Booking.com iCal availability feeds, one pair per villa.
# Copy this file to ".env.local" and paste the export URLs from each listing.
#
# Airbnb:      Listing > Availability > Sync calendars > Export calendar (copy the .ics link)
# Booking.com: Property > Rates & Availability > Sync calendars > Export (copy the .ics link)
#
# Any feed you leave blank is treated as fully available. After editing
# .env.local, restart the dev server.

ICAL_VIGNA_AIRBNB=
ICAL_VIGNA_BOOKING=

ICAL_LIMONE_AIRBNB=
ICAL_LIMONE_BOOKING=

ICAL_OLEANDRO_AIRBNB=
ICAL_OLEANDRO_BOOKING=

ICAL_FICO_AIRBNB=
ICAL_FICO_BOOKING=

ICAL_FRANTOIO_AIRBNB=
ICAL_FRANTOIO_BOOKING=

ICAL_NERINO_AIRBNB=
ICAL_NERINO_BOOKING=
